class Solution {
    public boolean canPartitionGrid(int[][] grid) {
        int r=grid.length;
        int c=grid[0].length;
        long s=0;
        int prev=0;
        long arr[]=new long[r];
        for(int i=0;i<r;i++){
            for(int j=0;j<c;j++){
                s+=grid[i][j];
            }
            arr[i]=s;
        }
        for(int i=0;i<r;i++){
            if(arr[i]+arr[i]==s) return true;
        }
        long sum=0;
        for(int j=0;j<c;j++){
            for(int i=0;i<r;i++){
                sum+=grid[i][j];
            }
            if(sum+sum==s) return true;
        }
        return false;
    }
}