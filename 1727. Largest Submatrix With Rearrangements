class Solution {
    public int largestSubmatrix(int[][] mat) {
        int r=mat.length;
        int c=mat[0].length;
        for(int i=1;i<r;i++){
            for(int j=0;j<c;j++){
                if(mat[i][j]>0){
                    mat[i][j]=mat[i-1][j]+1;
                }
            }
        }
        for(int i=0;i<r;i++){
            Arrays.sort(mat[i]);
            // System.out.println(mat[i][0]);
        }
        int max=Integer.MIN_VALUE;
        for(int i=0;i<r;i++){
            int ct=1;
            for(int j=c-1;j>=0;j--){
                max=Math.max(max,mat[i][j]*(ct++));
            }
        }

        return max;
    }
}